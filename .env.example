# ── Node API ──────────────────────────────────────────────
API_PORT=3000
API_HOST=0.0.0.0
CORS_ORIGIN=*
ALLOW_PRIVATE_TARGETS=true

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/easyformcv_dev

# ── Python services ────────────────────────────────────────
PDF_PARSER_URL=http://localhost:8001
BROWSER_AUTOMATION_URL=http://localhost:8002

# ── AI (optional — required for AI-assisted field mapping) ─
OPENAI_API_KEY=

# ── Frontend (Vite dev proxy target) ───────────────────────
VITE_API_URL=http://localhost:3000
