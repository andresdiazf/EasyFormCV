datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Profile {
  id        String   @id @default(uuid())
  fullName  String   @default("") @map("full_name")
  email     String   @default("")
  phone     String   @default("")
  location  String   @default("")
  summary   String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

model FormMapping {
  id           String   @id @default(uuid())
  url          String   @default("")
  fieldsJson   String   @default("[]") @map("fields_json")
  mappingsJson String   @default("[]") @map("mappings_json")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("form_mappings")
}

model Run {
  id              String   @id
  status          String   @default("pending")
  url             String   @default("")
  profileSnapshot String   @default("{}") @map("profile_snapshot")
  filledJson      String   @default("[]") @map("filled_json")
  failedJson      String   @default("[]") @map("failed_json")
  screenshotPath  String?  @map("screenshot_path")
  error           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("runs")
}
